---
import { getCollection } from 'astro:content';

const posts = await getCollection('docs', ({ id }) => {
  return id.startsWith('blog/');
});

// Sort posts by date (latest first)
const sortedPosts = posts.sort((a, b) => {
  const dateA = new Date(a.data.date || a.id.split('/').pop().slice(0, 10));
  const dateB = new Date(b.data.date || b.id.split('/').pop().slice(0, 10));
  return dateB - dateA;
}).slice(0, 4);

const formatDate = (post) => {
  const dateStr = post.data.date || post.id.split('/').pop().slice(0, 10);
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
};
---

<div class="news-feed-window not-content">
  <div class="window-header">
    <div class="header-controls">
      <span class="control">_</span>
      <span class="control">□</span>
      <span class="control">×</span>
    </div>
  </div>
  
  <div class="window-body">
    <div class="terminal-prompt">
      <span class="user">[root@purplesec</span> <span class="path">~]#</span> <span class="command">tail -f /var/log/latest.intel</span>
    </div>
    
    <div class="news-items">
      {sortedPosts.map(post => (
        <a href={`/${post.id}`} class="news-item">
          <span class="date">[{formatDate(post)}]</span>
          <span class="title">{post.data.title}</span>
        </a>
      ))}
    </div>
    
    <div class="scroll-indicators">
      <div class="arrow up">▲</div>
      <div class="arrow down">▼</div>
    </div>
  </div>
</div>

<style>
  .news-feed-window {
    background: #000000;
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 8px;
    height: 100%;
    display: flex;
    flex-direction: column;
    font-family: 'JetBrains Mono', monospace;
  }

  .window-header {
    background: rgba(34, 197, 94, 0.05);
    padding: 8px 12px;
    display: flex;
    justify-content: flex-end;
    border-bottom: 1px solid rgba(34, 197, 94, 0.1);
  }

  .header-controls {
    display: flex;
    gap: 8px;
    color: rgba(34, 197, 94, 0.4);
    font-size: 12px;
  }

  .window-body {
    padding: 1.5rem;
    position: relative;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .terminal-prompt {
    font-size: 0.85rem;
    margin-bottom: 1.5rem;
    border-bottom: 1px solid rgba(34, 197, 94, 0.1);
    padding-bottom: 0.5rem;
  }

  .terminal-prompt .user { color: #22c55e; }
  .terminal-prompt .path { color: #ffffff; }
  .terminal-prompt .command { color: #ffffff; }

  .news-items {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .news-item {
    text-decoration: none;
    display: flex;
    gap: 0.75rem;
    font-size: 0.9rem;
    line-height: 1.4;
    transition: transform 0.2s;
  }

  .news-item:hover {
    transform: translateX(5px);
  }

  .news-item .date {
    color: #22c55e;
    flex-shrink: 0;
  }

  .news-item .title {
    color: #ffffff;
    opacity: 0.9;
  }

  .news-item:hover .title {
    opacity: 1;
    color: #22c55e;
  }

  .scroll-indicators {
    position: absolute;
    right: 1rem;
    top: 50%;
    transform: translateY(-50%);
    display: flex;
    flex-direction: column;
    gap: 10rem;
    color: #22c55e;
    font-size: 0.7rem;
    opacity: 0.5;
  }

  .arrow {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
</style>
