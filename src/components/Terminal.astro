---
interface Props {
  lines?: string[];
  title?: string;
}

const { 
  title = "TERMINAL - PURPLESEC v1.0.4",
  lines = [
    "INITIALIZING PURPLESEC CORE...",
    "LOADING OFFENSIVE MODULES...",
    "DEFENSIVE SHIELDS: ONLINE",
    "TARGET: RESEARCH LABS",
    "STATUS: ACCESSING ENCRYPTED ARCHIVES...",
    "SUCCESS: KNOWLEDGE BASE SYNCHRONIZED."
  ] 
} = Astro.props;
---

<div class="ps-window not-content terminal-hero">
  <div class="ps-window-header">
    <div class="ps-window-controls">
      <span class="control">_</span>
      <span class="control">□</span>
      <span class="control">×</span>
    </div>
    <div class="ps-window-title">{title}</div>
    <div style="width: 42px;"></div> <!-- Spacer to center title -->
  </div>
  
  <div class="terminal-body">
    <div class="terminal-content">
      {lines.map((line, i) => (
        <div class="terminal-line" style={`animation-delay: ${i * 0.8}s`}>
          <span class="prompt">></span> {line}
        </div>
      ))}
      <div class="cursor-line">
        <span class="prompt">></span> <span class="cursor"></span>
      </div>
    </div>
  </div>
</div>

<style>
  .terminal-hero {
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
    text-align: left;
  }

  .ps-window-header {
    background: transparent;
    padding: 1.5rem 1.5rem 0;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    border-bottom: none;
  }

  .ps-window-controls {
    display: flex;
    gap: 6px;
    color: var(--ps-accent);
  }

  .control {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border: 1px solid var(--ps-accent);
    font-size: 10px;
    font-family: monospace;
    opacity: 0.8;
  }

  .terminal-body {
    padding: 1.5rem;
    background: var(--ps-window-bg);
    min-height: 250px;
  }

  .terminal-content {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: var(--ps-text);
  }

  .terminal-line {
    opacity: 0;
    animation: fadeIn 0.3s forwards;
    white-space: pre-wrap;
  }

  .prompt {
    color: var(--ps-accent);
    font-weight: bold;
    margin-right: 0.75rem;
  }

  .cursor {
    display: inline-block;
    width: 10px;
    height: 18px;
    background: var(--ps-accent);
    animation: blink 1s infinite;
    vertical-align: middle;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(5px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }
</style>
