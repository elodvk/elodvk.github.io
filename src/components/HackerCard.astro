---
interface Props {
  title: string;
  description: string;
  href?: string;
  icon?: 'shield' | 'skull' | 'code' | 'server';
}

const { title, description, href = "#", icon = 'shield' } = Astro.props;

const icons = {
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/></svg>`,
  skull: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="9" cy="12" r="1"/><circle cx="15" cy="12" r="1"/><path d="M8 20v2h8v-2"/><path d="m12.5 17-.5-1-.5 1h1z"/><path d="M16 20a2 2 0 0 0 1.56-3.25 8 8 0 1 0-11.12 0A2 2 0 0 0 8 20"/></svg>`,
  code: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  server: `<svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="8" x="2" y="2" rx="2" ry="2"/><rect width="20" height="8" x="2" y="14" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>`
};
---

<div class="hacker-card not-content">
  <div class="card-header">
    <div class="header-controls">
      <span class="control">_</span>
      <span class="control">□</span>
      <span class="control">×</span>
    </div>
  </div>
  
  <div class="card-body">
    <div class="card-icon" set:html={icons[icon]}></div>
    <h3 class="card-title">{title}</h3>
    <p class="card-description">{description}</p>
    <a href={href} class="card-link">Learn more <span class="arrow">→</span></a>
  </div>
</div>

<style>
  .hacker-card {
    background: #000000;
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 8px;
    height: 100%;
    display: flex;
    flex-direction: column;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    overflow: hidden;
  }

  .hacker-card:hover {
    border-color: #22c55e;
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.15);
    transform: translateY(-5px);
  }

  .card-header {
    background: rgba(34, 197, 94, 0.05);
    padding: 8px 12px;
    display: flex;
    justify-content: flex-end;
    border-bottom: 1px solid rgba(34, 197, 94, 0.1);
  }

  .header-controls {
    display: flex;
    gap: 8px;
    color: rgba(34, 197, 94, 0.4);
    font-family: monospace;
    font-size: 12px;
  }

  .card-body {
    padding: 2.5rem 1.5rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-icon {
    color: #22c55e;
    margin-bottom: 1.5rem;
  }

  .card-title {
    color: #22c55e !important;
    font-size: 1.5rem !important;
    font-weight: 700 !important;
    margin-bottom: 1rem !important;
    font-family: 'JetBrains Mono', monospace;
  }

  .card-description {
    color: #94a3b8 !important;
    font-size: 0.95rem !important;
    line-height: 1.6 !important;
    margin-bottom: 2rem !important;
  }

  .card-link {
    color: #22c55e;
    text-decoration: none;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin-top: auto;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    transition: gap 0.2s;
  }

  .card-link:hover {
    color: #4ade80;
    gap: 0.75rem;
  }

  .arrow {
    transition: transform 0.2s;
  }
</style>
