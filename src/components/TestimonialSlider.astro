---
const testimonials = [
  {
    quote: "Their zero-day research helped us identify and fix critical vulnerabilities before exploitation.",
    author: "Privacy Technology Company"
  }
];
---

<div class="testimonial-window not-content">
  <div class="window-header">
    <div class="header-controls">
      <span class="control">_</span>
      <span class="control">□</span>
      <span class="control">×</span>
    </div>
  </div>
  
  <div class="window-body">
    <div class="quote-icon">
      <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-quote"><path d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/><path d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c1.054 0 1.25.513 1.25 1.587V15c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"/></svg>
    </div>
    
    <div class="testimonial-content">
      <p class="quote">"{testimonials[0].quote}"</p>
      <p class="author">{testimonials[0].author}</p>
    </div>
    
    <div class="slider-controls">
      <div class="nav-arrow prev">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
      </div>
      <div class="dots">
        <span class="dot active"></span>
        <span class="dot"></span>
        <span class="dot"></span>
      </div>
      <div class="nav-arrow next">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
      </div>
    </div>
  </div>
</div>

<style>
  .testimonial-window {
    background: #000000;
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 8px;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .window-header {
    background: rgba(34, 197, 94, 0.05);
    padding: 8px 12px;
    display: flex;
    justify-content: flex-end;
    border-bottom: 1px solid rgba(34, 197, 94, 0.1);
  }

  .header-controls {
    display: flex;
    gap: 8px;
    color: rgba(34, 197, 94, 0.4);
    font-family: monospace;
    font-size: 12px;
  }

  .window-body {
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    flex-grow: 1;
  }

  .quote-icon {
    color: rgba(34, 197, 94, 0.3);
    margin-bottom: 2rem;
  }

  .quote {
    color: #ffffff;
    font-size: 1.25rem;
    line-height: 1.6;
    font-style: italic;
    margin-bottom: 1.5rem;
    max-width: 500px;
    font-family: 'JetBrains Mono', monospace;
  }

  .author {
    color: #94a3b8;
    font-size: 0.9rem;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 3rem;
  }

  .slider-controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav-arrow {
    width: 32px;
    height: 32px;
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #22c55e;
    cursor: pointer;
    transition: all 0.2s;
  }

  .nav-arrow:hover {
    background: rgba(34, 197, 94, 0.1);
    border-color: #22c55e;
  }

  .dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: rgba(34, 197, 94, 0.2);
    border-radius: 50%;
  }

  .dot.active {
    background: #22c55e;
    width: 24px;
    border-radius: 4px;
  }
</style>
