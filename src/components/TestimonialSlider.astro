---
const testimonials = [
  {
    quote:
      "If you think technology can solve your security problems, then you don't understand the problems and you don't understand the technology.",
    author:
      "Bruce Schneier (renowned cryptographer, security technologist, and author)",
  },
  {
    quote:
      "You can never protect yourself 100%. What you do is protect yourself as much as possible and mitigate risk to an acceptable degree.",
    author: "Kevin Mitnick",
  },
  {
    quote:
      "Zero Trust is not a technology; it’s a security philosophy that rewires how we think about access.",
    author: "John Kindervag",
  },
];
---

<div class="testimonial-window not-content" id="testimonial-slider" data-testimonials={JSON.stringify(testimonials)}>
  <div class="window-header">
    <div class="header-controls">
      <span class="control">_</span>
      <span class="control">□</span>
      <span class="control">×</span>
    </div>
  </div>

  <div class="window-body">
    <div class="quote-icon">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="48"
        height="48"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="lucide lucide-quote"
        ><path
          d="M3 21c3 0 7-1 7-8V5c0-1.25-.756-2.017-2-2H4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2 1 0 1 0 1 1v1c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"
        ></path><path
          d="M15 21c3 0 7-1 7-8V5c0-1.25-.757-2.017-2-2h-4c-1.25 0-2 .75-2 1.972V11c0 1.25.75 2 2 2h.75c1.054 0 1.25.513 1.25 1.587V15c0 1-1 2-2 2s-1 .008-1 1.031V20c0 1 0 1 1 1z"
        ></path></svg
      >
    </div>

    <div class="testimonial-content">
      <div class="quote-area">
        <p class="quote" id="slider-quote">"{testimonials[0].quote}"</p>
      </div>
      <div class="author-area">
        <p class="author" id="slider-author">{testimonials[0].author}</p>
      </div>
    </div>

    <div class="slider-controls">
      <div class="nav-arrow prev" id="prev-btn">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m15 18-6-6 6-6"></path></svg
        >
      </div>
      <div class="dots" id="dots-container">
        {testimonials.map((_, i) => (
          <div class="dot-slot">
            <span class={`dot ${i === 0 ? 'active' : ''}`} data-index={i}></span>
          </div>
        ))}
      </div>
      <div class="nav-arrow next" id="next-btn">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"><path d="m9 18 6-6-6-6"></path></svg
        >
      </div>
    </div>
  </div>
</div>

<script>
  const slider = document.getElementById('testimonial-slider');
  if (slider) {
    const testimonials = JSON.parse(slider.dataset.testimonials || '[]');
    const quoteEl = document.getElementById('slider-quote');
    const authorEl = document.getElementById('slider-author');
    const prevBtn = document.getElementById('prev-btn');
    const nextBtn = document.getElementById('next-btn');
    const dotsContainer = document.getElementById('dots-container');
    const dots = dotsContainer?.querySelectorAll('.dot');

    let currentIndex = 0;

    function updateSlider(index: number) {
      if (!quoteEl || !authorEl || !dots) return;
      
      currentIndex = index;
      if (currentIndex < 0) currentIndex = testimonials.length - 1;
      if (currentIndex >= testimonials.length) currentIndex = 0;

      quoteEl.textContent = `"${testimonials[currentIndex].quote}"`;
      authorEl.textContent = testimonials[currentIndex].author;

      dots.forEach((dot, i) => {
        if (i === currentIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    }

    prevBtn?.addEventListener('click', () => updateSlider(currentIndex - 1));
    nextBtn?.addEventListener('click', () => updateSlider(currentIndex + 1));

    dots?.forEach((dot) => {
      dot.addEventListener('click', () => {
        const index = parseInt((dot as HTMLElement).dataset.index || '0');
        updateSlider(index);
      });
    });
  }
</script>

<style>
  .testimonial-window {
    background: #000000;
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: 8px;
    height: 480px; /* Strictly fixed height */
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .window-header {
    background: rgba(34, 197, 94, 0.05);
    padding: 8px 12px;
    display: flex;
    justify-content: flex-end;
    border-bottom: 1px solid rgba(34, 197, 94, 0.1);
    height: 33px; /* Fixed header height */
    flex-shrink: 0;
  }

  .header-controls {
    display: flex;
    gap: 8px;
    color: rgba(34, 197, 94, 0.4);
    font-family: monospace;
    font-size: 12px;
  }

  .window-body {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    height: 447px; /* 480 - 33 */
    flex-shrink: 0;
    overflow: hidden;
  }

  .quote-icon {
    color: rgba(34, 197, 94, 0.3);
    margin-bottom: 1.5rem;
    height: 48px;
    flex-shrink: 0;
  }

  .testimonial-content {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    width: 100%;
    margin-bottom: 1.5rem;
    overflow: hidden;
  }

  .quote-area {
    height: 140px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    flex-shrink: 0;
  }

  .quote {
    color: #ffffff;
    font-size: 1.2rem;
    line-height: 1.6;
    font-style: italic;
    max-width: 500px;
    font-family: "JetBrains Mono", monospace;
    text-align: center;
  }

  .author-area {
    height: 40px; /* Fixed height for author to accommodate wrap if needed */
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .author {
    color: #94a3b8;
    font-size: 0.75rem;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-align: center;
  }

  .slider-controls {
    display: flex;
    align-items: center;
    gap: 2rem;
    height: 60px; /* Fixed height for controls */
    margin-top: auto;
    flex-shrink: 0;
  }

  .nav-arrow {
    width: 36px;
    height: 36px;
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #22c55e;
    cursor: pointer;
    transition: all 0.2s;
  }

  .nav-arrow:hover {
    background: rgba(34, 197, 94, 0.1);
    border-color: #22c55e;
  }

  .dots {
    display: flex;
    gap: 0.25rem;
    align-items: center;
    width: 100px;
    justify-content: center;
  }

  .dot-slot {
    width: 24px;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .dot {
    width: 8px;
    height: 8px;
    background: rgba(34, 197, 94, 0.2);
    border-radius: 50%;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .dot.active {
    background: #22c55e;
    width: 24px;
    border-radius: 4px;
  }

  @media (max-width: 480px) {
    .testimonial-window {
      height: 550px;
    }
    .window-body {
        height: 517px;
    }
  }
</style>
