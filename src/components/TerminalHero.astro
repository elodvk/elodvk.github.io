---
interface Props {
  title?: string;
  tagline?: string;
}

const {
  title = "PurpleSec",
  tagline = "Demystifying the technical hurdles of the cybersecurity landscape through transparent documentation, shared research, and the constant pursuit of a more secure future.",
} = Astro.props;
---

<div class="terminal-hero-container not-content">
  <div class="ps-window terminal-window">
    <div class="ps-window-header">
      <div class="ps-window-controls">
        <div class="ps-dot red"></div>
        <div class="ps-dot yellow"></div>
        <div class="ps-dot green"></div>
      </div>
      <div class="ps-window-title">TERMINAL - PURPLESEC v1.0.4</div>
      <div class="ps-window-actions">
        <span class="action-dot">_</span>
        <span class="action-dot">□</span>
        <span class="action-dot">×</span>
      </div>
    </div>

    <div class="terminal-body">
      <div class="terminal-overlay"></div>

      <div class="terminal-content">
        <div class="terminal-prompt">
          <span class="user">[user@purplesec</span>
          <span class="path">~]$</span>
          <span class="command" id="hero-command-text"></span><span class="cursor">_</span>
        </div>

        <div class="hero-main" id="hero-main-content" style="opacity: 0;">
          <h1 class="hero-title" id="hero-title-text" data-text={title}></h1>
          <p class="hero-tagline" id="hero-tagline-text" data-text={tagline}></p>

          <div class="hero-actions" id="hero-actions-container" style="opacity: 0;">
            <a href="/active_directory" class="btn btn-primary">Get Started</a>
            <a href="/blog" class="btn btn-outline">Blog</a>
          </div>
        </div>

        <div class="terminal-footer" id="hero-footer" style="opacity: 0;">
          <div class="terminal-prompt">
            <span class="user">[root@purplesec</span>
            <span class="path">~]#</span>
            <span class="command">id</span>
          </div>
          <div class="terminal-output">
            uid=0(root) gid=0(root) groups=0(root)
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-indicator">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
    >
  </div>
</div>

<script>
  async function typeWriter(elementId: string, text: string, speed: number = 50) {
    const element = document.getElementById(elementId);
    if (!element) return;
    
    for (let i = 0; i < text.length; i++) {
      element.textContent += text.charAt(i);
      await new Promise(resolve => setTimeout(resolve, speed));
    }
  }

  async function initAnimation() {
    const mainContent = document.getElementById('hero-main-content');
    const actions = document.getElementById('hero-actions-container');
    const footer = document.getElementById('hero-footer');
    const titleEl = document.getElementById('hero-title-text');
    const taglineEl = document.getElementById('hero-tagline-text');
    
    if (!mainContent || !actions || !footer || !titleEl || !taglineEl) return;

    // 1. Type the command
    await typeWriter('hero-command-text', './exploit.py', 40);
    await new Promise(resolve => setTimeout(resolve, 200));

    // 2. Reveal main content area
    mainContent.style.opacity = '1';
    
    // 3. Type Title
    const fullTitle = titleEl.getAttribute('data-text') || '';
    await typeWriter('hero-title-text', fullTitle, 30);
    await new Promise(resolve => setTimeout(resolve, 150));

    // 4. Type Tagline
    const fullTagline = taglineEl.getAttribute('data-text') || '';
    await typeWriter('hero-tagline-text', fullTagline, 10);
    await new Promise(resolve => setTimeout(resolve, 300));

    // 5. Reveal actions and footer
    actions.style.opacity = '1';
    actions.style.transition = 'opacity 0.4s ease-in';
    
    await new Promise(resolve => setTimeout(resolve, 200));
    footer.style.opacity = '1';
    footer.style.transition = 'opacity 0.4s ease-in';
  }

  // Run on load
  window.addEventListener('load', initAnimation);
</script>

<style>
  .terminal-hero-container {
    position: relative;
    width: 100%;
    max-width: 1000px;
    margin: 4rem auto;
    padding: 0 1rem;
    z-index: 10;
  }

  .terminal-window {
    background: rgba(5, 5, 7, 0.95);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(34, 211, 238, 0.2);
    box-shadow:
      0 0 50px rgba(0, 0, 0, 0.8),
      0 0 20px rgba(34, 211, 238, 0.05);
  }

  .ps-window-actions {
    display: flex;
    gap: 12px;
    color: #4b5563;
    font-family: monospace;
    font-size: 14px;
    margin-right: 8px;
  }

  .action-dot {
    cursor: pointer;
    transition: color 0.2s;
  }
  .action-dot:hover {
    color: #22d3ee;
  }

  .terminal-body {
    position: relative;
    padding: 5rem 2rem;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background-color: #050507;
    background-image: url("/cyber_terminal_mask_bg.png");
    background-size: 600px;
    background-position: center;
    background-repeat: no-repeat;
    background-blend-mode: overlay;
  }

  .terminal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.2) 50%),
      linear-gradient(
        90deg,
        rgba(255, 0, 0, 0.03),
        rgba(0, 255, 0, 0.01),
        rgba(0, 0, 255, 0.03)
      );
    background-size:
      100% 2px,
      3px 100%;
    pointer-events: none;
    z-index: 5;
    opacity: 0.5;
  }

  .terminal-content {
    position: relative;
    z-index: 2;
    font-family: "JetBrains Mono", monospace;
  }

  .terminal-prompt {
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .terminal-prompt .user {
    color: #22c55e;
  }
  .terminal-prompt .path {
    color: #ffffff;
  }
  .terminal-prompt .command {
    color: #ffffff;
  }

  .cursor {
    display: inline-block;
    width: 8px;
    background-color: #22c55e;
    margin-left: 4px;
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    from, to { opacity: 1; }
    50% { opacity: 0; }
  }

  .hero-main {
    text-align: center;
    margin: 3rem 0;
  }

  .hero-title {
    color: #22c55e !important;
    font-size: clamp(2rem, 5vw, 3.5rem) !important;
    font-weight: 800 !important;
    letter-spacing: 2px !important;
    margin-bottom: 1.5rem !important;
    text-transform: uppercase;
    text-shadow: 0 0 20px rgba(34, 197, 94, 0.3);
  }

  .hero-tagline {
    color: #cbd5e1 !important;
    font-size: 1.1rem !important;
    line-height: 1.6 !important;
    max-width: 700px;
    margin: 0 auto 2.5rem !important;
  }

  .hero-actions {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    margin-bottom: 2rem;
  }

  .terminal-footer {
    margin-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 1.5rem;
  }

  .terminal-output {
    color: #22c55e;
    font-size: 0.85rem;
    opacity: 0.9;
  }

  .scroll-indicator {
    position: absolute;
    bottom: -3rem;
    left: 50%;
    transform: translateX(-50%);
    color: #22c55e;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%,
    20%,
    50%,
    80%,
    100% {
      transform: translateY(0) translateX(-50%);
    }
    40% {
      transform: translateY(-10px) translateX(-50%);
    }
    60% {
      transform: translateY(-5px) translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .hero-actions {
      flex-direction: column;
      gap: 1rem;
    }
    .btn {
      width: 100%;
    }
    .terminal-body {
      padding: 2rem 1rem;
    }
  }
</style>
