---
interface Props {
  title?: string;
  tagline?: string;
}

const {
  title = "PurpleSec",
  tagline = "Demystifying the technical hurdles of the cybersecurity landscape through transparent documentation, shared research, and the constant pursuit of a more secure future.",
} = Astro.props;
---

<div class="terminal-hero-container not-content">
  <div class="ps-window terminal-window">
    <div class="ps-window-header hacker-header">
      <div class="ps-window-actions">
        <span class="control">_</span>
        <span class="control">□</span>
        <span class="control">×</span>
      </div>
    </div>

    <div class="terminal-body">
      <div class="terminal-overlay"></div>

      <div class="terminal-content">
        <div class="terminal-prompt">
          <span class="user">[user@purplesec</span>
          <span class="path">~]$</span>
          <span class="command" id="hero-command-text"></span><span class="cursor"></span>
        </div>

        <div class="hero-main" id="hero-main-content" style="opacity: 0;">
          <h1 class="hero-title glitch-hover" id="hero-title-text" data-text={title}></h1>
          <p class="hero-tagline" id="hero-tagline-text" data-text={tagline}>
          </p>

          <div
            class="hero-actions"
            id="hero-actions-container"
            style="opacity: 0;"
          >
            <a href="/active_directory" class="btn btn-primary">Get Started</a>
            <a href="/blog" class="btn btn-outline">Blog</a>
          </div>
        </div>

        <div class="terminal-footer" id="hero-footer" style="opacity: 0;">
          <div class="terminal-prompt">
            <span class="user">[root@purplesec</span>
            <span class="path">~]#</span>
            <span class="command">id</span>
          </div>
          <div class="terminal-output">
            uid=0(root) gid=0(root) groups=0(root), 512(Domain Admins), 519(Enterprise Admins)
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="scroll-indicator" id="hero-scroll-btn" role="button" aria-label="Scroll down">
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="m6 9 6 6 6-6"></path></svg
    >
  </div>
</div>

<script>
  async function typeWriter(
    elementId: string,
    text: string,
    speed: number = 50,
  ) {
    const element = document.getElementById(elementId);
    if (!element) return;

    for (let i = 0; i < text.length; i++) {
      element.textContent += text.charAt(i);
      await new Promise((resolve) => setTimeout(resolve, speed));
    }
  }

  async function initAnimation() {
    const mainContent = document.getElementById("hero-main-content");
    const actions = document.getElementById("hero-actions-container");
    const footer = document.getElementById("hero-footer");
    const titleEl = document.getElementById("hero-title-text");
    const taglineEl = document.getElementById("hero-tagline-text");

    if (!mainContent || !actions || !footer || !titleEl || !taglineEl) return;

    // 1. Type the command
    await typeWriter("hero-command-text", "./whoami --verbose", 40);
    await new Promise((resolve) => setTimeout(resolve, 200));

    // 2. Reveal main content area
    mainContent.style.opacity = "1";

    // 3. Type Title
    const fullTitle = titleEl.getAttribute("data-text") || "";
    await typeWriter("hero-title-text", fullTitle, 30);
    await new Promise((resolve) => setTimeout(resolve, 150));

    // 4. Type Tagline
    const fullTagline = taglineEl.getAttribute("data-text") || "";
    await typeWriter("hero-tagline-text", fullTagline, 10);
    await new Promise((resolve) => setTimeout(resolve, 300));

    // 5. Reveal actions and footer
    actions.style.opacity = "1";
    actions.style.transition = "opacity 0.4s ease-in";

    await new Promise((resolve) => setTimeout(resolve, 200));
    footer.style.opacity = "1";
    footer.style.transition = "opacity 0.4s ease-in";
  }

  // Run on load
  window.addEventListener("load", initAnimation);

  // Scroll Down Logic
  const scrollBtn = document.getElementById("hero-scroll-btn");
  if (scrollBtn) {
    scrollBtn.addEventListener("click", () => {
      // Find the bottom of the hero container and scroll to it, accounting for the sticky header
      const heroContainer = document.querySelector(".terminal-hero-container");
      if (heroContainer) {
        const offset = heroContainer.getBoundingClientRect().bottom + window.scrollY;
        window.scrollTo({ top: offset - 80, behavior: "smooth" });
      }
    });

    window.addEventListener("scroll", () => {
      if (window.scrollY > 50) {
        scrollBtn.style.opacity = "0";
        scrollBtn.style.pointerEvents = "none";
      } else {
        scrollBtn.style.opacity = "1";
        scrollBtn.style.pointerEvents = "auto";
      }
    });
  }
</script>

<style>
  .terminal-hero-container {
    position: relative;
    width: 100%;
    max-width: clamp(320px, 95vw, 900px);
    margin: 0 auto;
    padding: 0 clamp(0.5rem, 3vw, 1.5rem);
    z-index: 10;
    min-height: calc(100vh - 80px);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .terminal-window {
    background: #000000;
    border: 1px solid rgba(0, 255, 0, 0.4);
    border-radius: 8px;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.9);
  }

  .hacker-header {
    background: transparent;
    padding: 12px 16px;
    display: flex;
    justify-content: flex-end;
    border-bottom: none;
  }

  .ps-window-actions {
    display: flex;
    gap: 6px;
    color: #00ff00;
    font-family: monospace;
  }

  .control {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border: 1px solid #00ff00;
    font-size: 10px;
    font-family: monospace;
    opacity: 0.8;
  }

  .terminal-body {
    position: relative;
    padding: clamp(1rem, 5vw, 3rem);
    min-height: clamp(350px, 60vh, 600px);
    display: flex;
    flex-direction: column;
    background-color: var(--ps-window-bg);
  }

  .terminal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background:
      linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.2) 50%),
      linear-gradient(
        90deg,
        rgba(255, 0, 0, 0.03),
        rgba(0, 255, 0, 0.01),
        rgba(0, 0, 255, 0.03)
      );
    background-size:
      100% 2px,
      3px 100%;
    pointer-events: none;
    z-index: 5;
    opacity: 0.2;
  }

  .terminal-content {
    position: relative;
    z-index: 2;
    font-family: "JetBrains Mono", monospace;
  }

  .terminal-prompt {
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .terminal-prompt .user {
    color: var(--ps-accent);
  }
  .terminal-prompt .path {
    color: var(--ps-text);
  }
  .terminal-prompt .command {
    color: var(--ps-text);
  }

  .cursor {
    display: inline-block;
    width: 8px;
    height: 1em;
    background-color: var(--ps-accent);
    margin-left: 4px;
    vertical-align: middle;
    animation: blink 1s step-start infinite;
    box-shadow: 0 0 6px var(--ps-accent-dim);
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
      box-shadow: none;
    }
  }

  .hero-main {
    text-align: center;
    margin: clamp(1rem, 3vh, 2rem) auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .hero-title {
    color: var(--ps-accent) !important;
    font-size: clamp(1.8rem, 4.5vw, 3rem) !important;
    font-weight: 500 !important;
    letter-spacing: 4px !important;
    margin-bottom: 1rem !important;
    text-transform: uppercase;
    font-family: 'JetBrains Mono', monospace;
  }

  .hero-tagline {
    color: var(--ps-text-muted) !important;
    font-size: 1rem !important;
    line-height: 1.5 !important;
    max-width: 800px;
    margin: 0 auto 1.5rem auto !important;
    text-align: center;
  }

  .hero-actions {
    display: flex;
    gap: clamp(0.75rem, 2vw, 1.5rem);
    justify-content: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .terminal-footer {
    margin-top: auto;
    padding-top: 0.5rem;
    border-top: none;
  }

  .terminal-output {
    color: var(--ps-accent);
    font-size: 0.85rem;
    opacity: 0.9;
  }

  .scroll-indicator {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: var(--ps-accent);
    animation: bounce 2s infinite;
    cursor: pointer;
    z-index: 50;
    transition: opacity 0.3s ease;
  }

  .scroll-indicator:hover {
    color: var(--sl-color-accent-high);
    text-shadow: 0 0 8px var(--ps-accent-dim);
  }

  @keyframes bounce {
    0%,
    20%,
    50%,
    80%,
    100% {
      transform: translateY(0) translateX(-50%);
    }
    40% {
      transform: translateY(-10px) translateX(-50%);
    }
    60% {
      transform: translateY(-5px) translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .terminal-hero-container {
      padding: 0 0.5rem;
      min-height: calc(100vh - 60px);
      justify-content: flex-start;
      padding-top: 2rem;
    }
    .terminal-body {
      padding: clamp(1rem, 3vw, 1.5rem) clamp(0.75rem, 2vw, 1rem);
      min-height: clamp(300px, 50vh, 450px);
      height: auto;
    }
    .hero-title {
      font-size: 1.5rem !important;
      letter-spacing: 2px !important;
    }
    .hero-tagline {
      font-size: 0.85rem !important;
    }
    .hero-actions {
      flex-direction: column;
      gap: 0.75rem;
      width: 100%;
    }
    .btn {
      width: 100%;
      padding: 0.6rem 1rem;
    }
    .terminal-footer {
      display: none;
    }
    .scroll-indicator {
      display: none;
    }
  }
</style>
