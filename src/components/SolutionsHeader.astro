---
interface Props {
  title?: string;
}

const { title = "Deffensive & Offensive Security" } = Astro.props;
---

<div class="solutions-header-container not-content">
  <div class="solutions-banner">
    <div class="banner-overlay"></div>
    <h2 class="banner-title">{title}</h2>
  </div>
</div>

<style>
  .solutions-header-container {
    width: 100%;
    max-width: 1200px;
    margin: 4rem auto 2rem;
    padding: 0 1rem;
  }

  .solutions-banner {
    position: relative;
    height: 180px;
    background-image: url("/solutions_header_bg.png");
    background-size: cover;
    background-position: center;
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(34, 197, 94, 0.1);
  }

  .banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(2px);
  }

  .banner-title {
    position: relative;
    z-index: 2;
    color: #22c55e !important;
    font-size: clamp(1.5rem, 4vw, 2.5rem) !important;
    font-weight: 800 !important;
    letter-spacing: 4px !important;
    text-transform: uppercase;
    text-align: center;
    text-shadow: 0 0 20px rgba(34, 197, 94, 0.5);
    margin: 0 !important;
  }

  @media (max-width: 768px) {
    .solutions-banner {
      height: 120px;
    }
  }
</style>
