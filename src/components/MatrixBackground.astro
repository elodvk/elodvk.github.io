<canvas id="matrix-canvas" class="not-content"></canvas>

<script>
  const canvas = document.getElementById("matrix-canvas");
  const ctx = canvas.getContext("2d");

  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  // Authentic Matrix characters: Katakana + Latin + Numbers
  const latin = "ABCDEFGHIJKLMNOPQRSTUVWXYZ";
  const nums = "0123456789";
  const katakana = "アァカサタナハマヤャラワガザダバパイィキシチニヒミリヰギジヂビピウゥクスツヌフムユュルグズヅブプエェケセテネヘメレヱゲゼデベペオォコソトノホモヨョロヲゴゾドボポヴッン";
  const characters = latin + nums + katakana;

  const fontSize = 12; // Reduced size for a more subtle look
  let columns = Math.ceil(width / fontSize);

  let drops = [];
  let speeds = [];

  function initDrops() {
    columns = Math.ceil(width / fontSize);
    drops = [];
    speeds = [];
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -100; // Randomize start positions above screen
      speeds[i] = Math.random() * 0.5 + 0.2; // Slower, more varied speeds
    }
  }

  initDrops();

  let lastTime = 0;
  const fps = 25; // Controlled frame rate for "cinematic" feel
  const nextFrame = 1000 / fps;
  let timer = 0;

  function draw(timeStamp) {
    const deltaTime = timeStamp - lastTime;
    lastTime = timeStamp;

    if (timer > nextFrame) {
      // Semi-transparent black to create trailing effect
      ctx.fillStyle = "rgba(0, 0, 0, 0.1)";
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = fontSize + "px monospace";

      for (let i = 0; i < drops.length; i++) {
        const text = characters.charAt(Math.floor(Math.random() * characters.length));
        const x = i * fontSize;
        const y = drops[i] * fontSize;

        // Head of the drop
        if (Math.random() > 0.98) {
          ctx.fillStyle = "#fff"; // Bright leading character
          ctx.shadowBlur = 8;
          ctx.shadowColor = "#fff";
        } else {
          ctx.fillStyle = "#0f0"; // Classic Matrix green
          ctx.shadowBlur = 0;
        }

        // Draw character
        ctx.fillText(text, x, y);

        // Move drop
        drops[i] += speeds[i];

        // Reset drop
        if (y > canvas.height && Math.random() > 0.975) {
          drops[i] = 0;
        }
      }
      timer = 0;
    } else {
      timer += deltaTime;
    }

    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);

  window.addEventListener("resize", () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
    initDrops();
  });
</script>

<style>
  #matrix-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    opacity: 0.15; /* Reduced opacity for a more professional, subtle look */
    pointer-events: none;
    background: #000;
  }
</style>
