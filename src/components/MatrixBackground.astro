<canvas id="matrix-canvas" class="not-content"></canvas>

<script>
  const canvas = document.getElementById("matrix-canvas");
  const ctx = canvas.getContext("2d");

  let width = window.innerWidth;
  let height = window.innerHeight;
  canvas.width = width;
  canvas.height = height;

  // Authentic hacker.house style: Binary only
  const characters = "01";

  const fontSize = 18; // Larger size for better readability of binary
  let columns = Math.ceil(width / fontSize);

  let drops = [];
  let speeds = [];

  function initDrops() {
    columns = Math.ceil(width / fontSize);
    drops = [];
    speeds = [];
    for (let i = 0; i < columns; i++) {
      drops[i] = Math.random() * -100; // Randomize start positions above screen
      speeds[i] = Math.random() * 0.8 + 0.5; // Fast rain speeds
    }
  }

  initDrops();

  let lastTime = 0;
  const fps = 25; // Controlled frame rate for "cinematic" feel
  const nextFrame = 1000 / fps;
  let timer = 0;

  function draw(timeStamp) {
    const deltaTime = timeStamp - lastTime;
    lastTime = timeStamp;

    if (timer > nextFrame) {
      // Fetch dynamic colors from theme variables
      const style = getComputedStyle(document.documentElement);
      const matrixColor = style.getPropertyValue('--ps-matrix-color').trim() || "#00ff00";
      const matrixHead = style.getPropertyValue('--ps-matrix-head').trim() || "rgba(255, 255, 255, 0.8)";
      const matrixBg = style.getPropertyValue('--ps-matrix-bg').trim() || "rgba(0, 0, 0, 0.05)";

      // Semi-transparent background to create trailing effect
      ctx.fillStyle = matrixBg;
      ctx.fillRect(0, 0, canvas.width, canvas.height);

      ctx.font = fontSize + "px 'JetBrains Mono', Courier, monospace";

      for (let i = 0; i < drops.length; i++) {
        const text = characters.charAt(Math.floor(Math.random() * characters.length));
        const x = i * fontSize;
        const y = drops[i] * fontSize;

        // Head of the drop
        if (Math.random() > 0.98) {
          ctx.fillStyle = matrixHead;
          ctx.shadowBlur = 5;
          ctx.shadowColor = matrixHead;
        } else {
          ctx.fillStyle = matrixColor;
          ctx.shadowBlur = 0;
        }

        // Draw character
        ctx.fillText(text, x, y);

        // Move drop
        drops[i] += speeds[i];

        // Reset drop
        if (y > canvas.height && Math.random() > 0.975) {
          drops[i] = 0;
        }
      }
      timer = 0;
    } else {
      timer += deltaTime;
    }

    requestAnimationFrame(draw);
  }

  requestAnimationFrame(draw);

  window.addEventListener("resize", () => {
    width = window.innerWidth;
    height = window.innerHeight;
    canvas.width = width;
    canvas.height = height;
    initDrops();
  });
</script>

<style>
  #matrix-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    opacity: 0.15;
    pointer-events: none;
    background: var(--sl-color-bg);
  }
</style>
